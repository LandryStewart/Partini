<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🍸 Cocktail Finder</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *{margin:0;padding:0;box-sizing:border-box;}
        body{font-family:'Poppins',sans-serif;background:#000;color:#eee;min-height:100vh;}
        header{background:linear-gradient(135deg,#0a0a0a,#111);text-align:center;padding:36px 20px 28px;border-bottom:3px solid #e2b340;}
        header h1{font-size:2.4rem;color:#e2b340;letter-spacing:1px;}
        header p{margin-top:6px;font-weight:300;color:#999;font-size:1rem;}
        .container{max-width:1200px;margin:0 auto;padding:28px 20px 60px;}
        .step{margin-bottom:28px;}
        .step-header{display:flex;align-items:center;gap:12px;margin-bottom:16px;}
        .step-num{background:#e2b340;color:#000;width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1rem;flex-shrink:0;}
        .step-header h2{font-size:1.2rem;font-weight:600;color:#ccc;}
        .spirits-grid{display:flex;flex-wrap:wrap;gap:12px;}
        .spirit-btn{background:#111;border:2px solid #222;border-radius:12px;padding:14px 18px;cursor:pointer;text-align:center;transition:all .25s;min-width:100px;user-select:none;}
        .spirit-btn:hover{border-color:#e2b340;background:#1a1a1a;}
        .spirit-btn.active{border-color:#e2b340;background:#1a1a00;box-shadow:0 0 14px rgba(226,179,64,.25);}
        .spirit-btn .emoji{font-size:1.6rem;display:block;margin-bottom:4px;}
        .spirit-btn .label{font-size:.82rem;font-weight:500;color:#aaa;}
        .spirit-btn.active .label{color:#e2b340;}
        .ing-section{background:#111;border-radius:14px;padding:24px;box-shadow:0 4px 20px rgba(0,0,0,.6);border:1px solid #1a1a1a;}
        .tabs{display:flex;gap:0;margin-bottom:20px;border-bottom:2px solid #222;}
        .tab-btn{padding:10px 22px;cursor:pointer;font-family:'Poppins',sans-serif;font-size:.92rem;font-weight:500;color:#666;background:none;border:none;border-bottom:3px solid transparent;transition:all .25s;}
        .tab-btn:hover{color:#bbb;}
        .tab-btn.active{color:#e2b340;border-bottom-color:#e2b340;}
        .tab-content{display:none;}.tab-content.active{display:block;}
        .cat-group{margin-bottom:18px;}
        .cat-title{font-size:.85rem;font-weight:600;color:#e2b340;margin-bottom:8px;text-transform:uppercase;letter-spacing:.5px;}
        .chips{display:flex;flex-wrap:wrap;gap:8px;}
        .chip{background:#0a0a0a;border:1.5px solid #222;border-radius:20px;padding:6px 14px;font-size:.82rem;color:#999;cursor:pointer;transition:all .2s;user-select:none;}
        .chip:hover{border-color:#e2b340;color:#ddd;}
        .chip.active{background:#1a1a00;border-color:#e2b340;color:#e2b340;}
        .search-wrap{position:relative;max-width:500px;}
        .search-wrap input{width:100%;padding:12px 18px;border-radius:8px;border:2px solid #222;background:#0a0a0a;color:#eee;font-family:'Poppins',sans-serif;font-size:1rem;outline:none;transition:border-color .25s;}
        .search-wrap input:focus{border-color:#e2b340;}
        .search-wrap input::placeholder{color:#444;}
        .autocomplete-list{position:absolute;top:100%;left:0;right:0;background:#111;border:1px solid #222;border-radius:0 0 8px 8px;max-height:260px;overflow-y:auto;z-index:100;display:none;}
        .autocomplete-list .ac-item{padding:10px 18px;cursor:pointer;font-size:.9rem;color:#aaa;transition:background .15s;}
        .autocomplete-list .ac-item:hover{background:#1a1a1a;color:#e2b340;}
        .autocomplete-list .ac-item.already{color:#444;font-style:italic;}
        .selected-bar{background:#0a0a0a;border:2px solid #1a1a1a;border-radius:12px;padding:16px 20px;margin:24px 0;min-height:56px;}
        .selected-label{font-size:.82rem;color:#666;margin-bottom:8px;font-weight:500;}
        .selected-tags{display:flex;flex-wrap:wrap;gap:8px;}
        .sel-tag{background:#1a1a00;border:1px solid #e2b340;color:#e2b340;padding:5px 12px;border-radius:18px;font-size:.82rem;display:flex;align-items:center;gap:6px;animation:fadeIn .3s;}
        .sel-tag .remove{cursor:pointer;font-weight:700;font-size:.95rem;transition:color .2s;}
        .sel-tag .remove:hover{color:#e74c3c;}
        .no-ing{color:#444;font-size:.88rem;font-style:italic;}
        .btn{padding:12px 22px;border:none;border-radius:8px;font-family:'Poppins',sans-serif;font-size:.95rem;font-weight:600;cursor:pointer;transition:background .25s,transform .15s;}
        .btn:active{transform:scale(.97);}
        .action-row{display:flex;gap:12px;margin-top:10px;flex-wrap:wrap;}
        .btn-find{background:#e2b340;color:#000;padding:14px 32px;font-size:1.05rem;position:relative;}
        .btn-find:hover{background:#f0c24d;}
        .btn-find .badge{position:absolute;top:-8px;right:-8px;background:#e74c3c;color:#fff;font-size:.72rem;width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;}
        .btn-clear{background:#c0392b;color:#fff;}
        .btn-clear:hover{background:#e74c3c;}
        .spinner-wrap{text-align:center;padding:50px 0;display:none;}
        .spinner{width:50px;height:50px;border:5px solid #111;border-top:5px solid #e2b340;border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 14px;}
        @keyframes spin{to{transform:rotate(360deg);}}
        @keyframes fadeIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
        @keyframes modalIn{from{opacity:0;transform:scale(.95);}to{opacity:1;transform:scale(1);}}
        .main-section-title{font-size:1.5rem;font-weight:700;margin:36px 0 8px;padding-bottom:8px;border-bottom:3px solid #e2b340;display:flex;align-items:center;gap:10px;color:#eee;}
        .main-section-title .icon{font-size:1.5rem;}
        .flavor-section{margin:18px 0;border:1px solid #1a1a1a;border-radius:12px;overflow:hidden;background:#0a0a0a;}
        .flavor-header{display:flex;align-items:center;gap:10px;padding:14px 20px;cursor:pointer;user-select:none;transition:background .2s;}
        .flavor-header:hover{background:#111;}
        .flavor-header .fl-emoji{font-size:1.3rem;}
        .flavor-header .fl-title{font-size:1.05rem;font-weight:600;color:#e2b340;flex:1;}
        .flavor-header .fl-count{font-size:.82rem;color:#666;margin-right:8px;}
        .flavor-header .fl-arrow{font-size:1rem;color:#666;transition:transform .3s;}
        .flavor-header .fl-arrow.open{transform:rotate(180deg);}
        .flavor-body{padding:0 16px 16px;}
        .flavor-body.collapsed{display:none;}
        .cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:18px;padding-top:8px;}
        .card{background:#141414;border-radius:14px;overflow:hidden;border:1px solid #1e1e1e;animation:fadeIn .4s;transition:transform .25s,border-color .25s;cursor:pointer;}
        .card:hover{transform:translateY(-4px);border-color:#e2b340;}
        .card img{width:100%;height:180px;object-fit:cover;}
        .card-body{padding:14px;}
        .card-body h3{color:#e2b340;font-size:1rem;margin-bottom:6px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
        .card-info{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
        .flavor-badge{font-size:.85rem;}
        .diff-badge{font-size:.72rem;padding:2px 9px;border-radius:10px;font-weight:600;}
        .badge-easy{background:#27ae60;color:#fff;}
        .badge-medium{background:#e2b340;color:#000;}
        .badge-advanced{background:#e74c3c;color:#fff;}
        .ing-count{font-size:.78rem;color:#666;margin-left:auto;}
        .no-results{text-align:center;padding:40px 20px;color:#555;font-size:1.05rem;}
        /* ── Modal ── */
        .modal-overlay{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.88);z-index:1000;justify-content:center;align-items:center;padding:20px;}
        .modal-overlay.open{display:flex;}
        .modal-card{background:#141414;border:1px solid #222;border-radius:16px;max-width:600px;width:100%;max-height:90vh;overflow-y:auto;position:relative;animation:modalIn .3s ease;}
        .modal-close{position:absolute;top:12px;right:12px;width:36px;height:36px;border-radius:50%;background:rgba(0,0,0,.6);color:#eee;border:none;font-size:1.2rem;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:10;transition:background .2s;}
        .modal-close:hover{background:#e74c3c;}
        .modal-img{width:100%;height:280px;object-fit:cover;border-radius:16px 16px 0 0;}
        .modal-body{padding:24px;}
        .modal-body h2{color:#e2b340;font-size:1.4rem;margin-bottom:4px;}
        .modal-meta{font-size:.85rem;color:#666;margin-bottom:14px;}
        .modal-meta span{margin-right:12px;}
        .modal-body h4{font-size:.95rem;color:#ccc;margin:16px 0 8px;border-bottom:1px solid #222;padding-bottom:6px;}
        .modal-ingredients{list-style:none;margin-bottom:6px;}
        .modal-ingredients li{font-size:.9rem;padding:4px 0;color:#bbb;}
        .modal-ingredients li::before{content:"• ";color:#e2b340;}
        .modal-ingredients li.missing{color:#e74c3c;font-style:italic;}
        .modal-ingredients li.missing::before{content:"✗ ";color:#e74c3c;}
        .modal-steps{list-style:none;counter-reset:step;}
        .modal-steps li{counter-increment:step;padding:6px 0;font-size:.88rem;color:#bbb;line-height:1.6;display:flex;gap:10px;}
        .modal-steps li::before{content:counter(step);background:#e2b340;color:#000;width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.78rem;flex-shrink:0;margin-top:2px;}
        @media(max-width:600px){
            header h1{font-size:1.7rem;}
            .cards{grid-template-columns:1fr;}
            .spirit-btn{min-width:80px;padding:10px 12px;}
            .spirit-btn .emoji{font-size:1.3rem;}
            .modal-card{max-width:95%;}
            .modal-img{height:200px;}
        }
    </style>
</head>
<body>

<header>
    <h1>🍸 Cocktail Finder</h1>
    <p>Pick your spirits, choose your ingredients, and discover what you can mix!</p>
</header>

<div class="container">

    <!-- STEP 1: Spirits -->
    <div class="step">
        <div class="step-header">
            <div class="step-num">1</div>
            <h2>Choose Your Base Spirit(s)</h2>
        </div>
        <div class="spirits-grid" id="spiritsGrid"></div>
    </div>

    <!-- STEP 2: Ingredients -->
    <div class="step">
        <div class="step-header">
            <div class="step-num">2</div>
            <h2>Add Your Ingredients</h2>
        </div>
        <div class="ing-section">
            <div class="tabs">
                <button class="tab-btn active" onclick="switchTab('browse')">📋 Browse &amp; Select</button>
                <button class="tab-btn" onclick="switchTab('search')">🔎 Type to Search</button>
            </div>
            <div class="tab-content active" id="tab-browse"></div>
            <div class="tab-content" id="tab-search">
                <p style="font-size:.88rem;color:#666;margin-bottom:12px;">Start typing — suggestions from the database will appear.</p>
                <div class="search-wrap">
                    <input type="text" id="searchInput" placeholder="e.g. Elderflower, Passion Fruit…" autocomplete="off">
                    <div class="autocomplete-list" id="acList"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Selected Summary -->
    <div class="selected-bar">
        <div class="selected-label">🧾 Selected Ingredients</div>
        <div class="selected-tags" id="selectedTags"><span class="no-ing">None selected yet — pick some above!</span></div>
    </div>

    <!-- Actions -->
    <div class="action-row">
        <button class="btn btn-find" id="findBtn" onclick="findCocktails()">🔍 Find Cocktails <span class="badge" id="countBadge" style="display:none">0</span></button>
        <button class="btn btn-clear" onclick="clearAll()">🗑️ Clear All</button>
    </div>

    <div class="spinner-wrap" id="spinner">
        <div class="spinner"></div>
        <p>Searching cocktail recipes…</p>
    </div>

    <div id="results"></div>
</div>

<!-- Modal -->
<div class="modal-overlay" id="modal" onclick="if(event.target===this)closeModal()">
    <div class="modal-card" id="modalCard">
        <button class="modal-close" onclick="closeModal()">✕</button>
        <div id="modalContent"></div>
    </div>
</div>

<script>
/* ═══════════════════════════════════════
