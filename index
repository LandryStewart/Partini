document.addEventListener('DOMContentLoaded', () => {
    renderSpirits();
    renderBrowseGrid();
    fetchIngredientList();
    setupAutocomplete();
});

async function fetchIngredientList() {
    try {
        const res = await fetch(`${API}/list.php?i=list`);
        const data = await res.json();
        if (data.drinks) {
            allIngredients = data.drinks.map(d => d.strIngredient1).filter(Boolean).sort();
        }
    } catch(e) { console.warn('Could not fetch ingredient list', e); }
}

/* ═══════════════════════════════════════
   SPIRITS
   ═══════════════════════════════════════ */
function renderSpirits() {
    document.getElementById('spiritsGrid').innerHTML = SPIRITS.map(s => `
        <div class="spirit-btn" data-name="${s.name}" onclick="toggleSpirit(this,'${s.name}')">
            <span class="emoji">${s.emoji}</span>
            <span class="label">${s.name}</span>
        </div>`).join('');
}
function toggleSpirit(el, name) {
    if (selected.has(name)) { selected.delete(name); el.classList.remove('active'); }
    else { selected.add(name); el.classList.add('active'); }
    renderSelected();
}

/* ═══════════════════════════════════════
   BROWSE GRID
   ═══════════════════════════════════════ */
function renderBrowseGrid() {
    const container = document.getElementById('tab-browse');
    let html = '';
    for (const [cat, items] of Object.entries(CATEGORIES)) {
        html += `<div class="cat-group"><div class="cat-title">${cat}</div><div class="chips">`;
        items.forEach(item => {
            const esc = item.replace(/'/g, "\\'");
            html += `<div class="chip" data-name="${item}" onclick="toggleChip(this,'${esc}')">${item}</div>`;
        });
        html += `</div></div>`;
    }
    container.innerHTML = html;
}
function toggleChip(el, name) {
    if (selected.has(name)) { selected.delete(name); el.classList.remove('active'); }
    else { selected.add(name); el.classList.add('active'); }
    renderSelected();
}

/* ═══════════════════════════════════════
   TABS
   ═══════════════════════════════════════ */
function switchTab(tab) {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
    if (tab === 'browse') {
        document.querySelectorAll('.tab-btn')[0].classList.add('active');
        document.getElementById('tab-browse').classList.add('active');
    } else {
        document.querySelectorAll('.tab-btn')[1].classList.add('active');
        document.getElementById('tab-search').classList.add('active');
    }
}

/* ═══════════════════════════════════════
   AUTOCOMPLETE
   ═══════════════════════════════════════ */
function setupAutocomplete() {
    const input = document.getElementById('searchInput');
    const list = document.getElementById('acList');
    input.addEventListener('input', () => {
        const val = input.value.trim().toLowerCase();
        if (val.length < 1) { list.style.display = 'none'; return; }
        const matches = allIngredients.filter(i => i.toLowerCase().includes(val)).slice(0, 10);
        if (matches.length === 0) { list.style.display = 'none'; return; }
        list.innerHTML = matches.map(m => {
            const already = selected.has(m);
            const esc = m.replace(/'/g, "\\'");
            return `<div class="ac-item${already ? ' already' : ''}" onclick="addFromSearch('${esc}')">${m}${already ? ' ✓' : ''}</div>`;
        }).join('');
        list.style.display = 'block';
    });
    input.addEventListener('keydown', e => {
        if (e.key === 'Enter') {
            const val = input.value.trim();
            if (val) { selected.add(val); renderSelected(); syncUI(); input.value = ''; list.style.display = 'none'; }
        }
    });
    document.addEventListener('click', e => {
        if (!e.target.closest('.search-wrap')) list.style.display = 'none';
    });
}
function addFromSearch(name) {
    selected.add(name);
    renderSelected();
    syncUI();
    document.getElementById('searchInput').value = '';
    document.getElementById('acList').style.display = 'none';
}

/* ═══════════════════════════════════════
   SELECTED TAGS
   ═══════════════════════════════════════ */
function renderSelected() {
    const area = document.getElementById('selectedTags');
    const badge = document.getElementById('countBadge');
    if (selected.size === 0) {
        area.innerHTML = '<span class="no-ing">None selected yet — pick some above!</span>';
        badge.style.display = 'none';
    } else {
        area.innerHTML = [...selected].map(s => {
            const esc = s.replace(/'/g, "\\'");
            return `<div class="sel-tag">${s}<span class="remove" onclick="removeSelected('${esc}')">✕</span></div>`;
        }).join('');
        badge.textContent = selected.size;
        badge.style.display = 'flex';
    }
}
function removeSelected(name) {
    selected.delete(name);
    renderSelected();
    syncUI();
}
function syncUI() {
    document.querySelectorAll('.spirit-btn').forEach(btn => btn.classList.toggle('active', selected.has(btn.dataset.name)));
    document.querySelectorAll('.chip').forEach(chip => chip.classList.toggle('active', selected.has(chip.dataset.name)));
}
function clearAll() {
    selected.clear();
    renderSelected();
    syncUI();
    document.getElementById('results').innerHTML = '';
    allResults = [];
}

/* ═══════════════════════════════════════
   FLAVOR CLASSIFICATION
   ═══════════════════════════════════════ */
function classifyFlavor(drinkIngredients, overrideFlavor) {
    if (overrideFlavor) return overrideFlavor;
    if (drinkIngredients.length <= 3) return 'quick';
    const allIng = drinkIngredients.map(di => di.name.toLowerCase());
    const combined = allIng.join(' ');
    let bestKey = 'bold';
    let bestScore = 0;
    for (const profile of FLAVOR_PROFILES) {
        if (profile.key === 'quick') continue;
        let score = 0;
        for (const kw of profile.keywords) {
            if (allIng.some(ing => ing.includes(kw) || kw.includes(ing)) || combined.includes(kw)) score++;
        }
        if (score > bestScore) { bestScore = score; bestKey = profile.key; }
    }
    return bestKey;
}
function getProfile(key) {
    return FLAVOR_PROFILES.find(p => p.key === key) || FLAVOR_PROFILES[FLAVOR_PROFILES.length - 1];
}

/* ═══════════════════════════════════════
   COLLAPSIBLE SECTIONS
   ═══════════════════════════════════════ */
function toggleFlavor(id) {
    const body = document.getElementById('fb-' + id);
    const arrow = document.getElementById('fa-' + id);
    if (body.classList.contains('collapsed')) { body.classList.remove('collapsed'); arrow.classList.add('open'); }
    else { body.classList.add('collapsed'); arrow.classList.remove('open'); }
}

/* ═══════════════════════════════════════
   MATCHING HELPERS
   ═══════════════════════════════════════ */
function norm(s) { return s.toLowerCase().replace(/[^a-z0-9 ]/g, '').trim(); }

function ingredientMatch(cocktailIng, userSet) {
    const ci = norm(cocktailIng);
    return [...userSet].some(ui => {
        const n = norm(ui);
        return ci.includes(n) || n.includes(ci);
    });
}

function parseSteps(text) {
    if (!text) return ['Follow the recipe instructions.'];
    // Try numbered patterns: "1." "2." etc.
    const numbered = text.split(/\d+\.\s+/).filter(s => s.trim().length > 0);
    if (numbered.length > 1) return numbered.map(s => s.trim().replace(/\.\s*$/, '.'));
    // Split by sentences
    const sentences = text.split(/\.\s+/).filter(s => s.trim().length > 3);
    if (sentences.length > 1) return sentences.map(s => s.trim().replace(/\.\s*$/, '') + '.');
    return [text.trim()];
}

function getDifficulty(count) {
    if (count <= 3) return 'Easy';
    if (count <= 5) return 'Medium';
    return 'Advanced';
}

/* ═══════════════════════════════════════
   FIND COCKTAILS (HYBRID)
   ═══════════════════════════════════════ */
async function findCocktails() {
    if (selected.size === 0) { alert('Please select at least one ingredient!'); return; }
    const resultsDiv = document.getElementById('results');
    const spinnerEl = document.getElementById('spinner');
    resultsDiv.innerHTML = '';
    spinnerEl.style.display = 'block';
    allResults = [];

    const fullMatch = [];
    const almostMatch = [];

    // ── A) Search LOCAL_DB ──
    for (const drink of LOCAL_DB) {
        let missing = [], have = [];
        drink.ingredients.forEach(di => {
            if (ingredientMatch(di.name, selected)) have.push(di);
            else missing.push(di);
        });
        if (missing.length === 0 || missing.length <= 2) {
            const obj = {
                drink: { strDrink: drink.name, strDrinkThumb: drink.img || DEFAULT_IMG, strCategory: drink.category, strGlass: drink.glass, strInstructions: drink.steps.join(' ') },
                drinkIngredients: drink.ingredients,
                missing, have,
                flavor: drink.flavor || classifyFlavor(drink.ingredients, null),
                difficulty: drink.difficulty,
                steps: drink.steps,
                source: 'local'
            };
            if (missing.length === 0) fullMatch.push(obj);
            else almostMatch.push(obj);
        }
    }

    // ── B) Search TheCocktailDB API ──
    try {
        const cocktailMap = {};
        for (const ing of selected) {
            try {
                const res = await fetch(`${API}/filter.php?i=${encodeURIComponent(ing)}`);
                const data = await res.json();
                if (data.drinks) {
                    data.drinks.forEach(d => {
                        if (!cocktailMap[d.idDrink]) cocktailMap[d.idDrink] = { count: 0, name: d.strDrink, thumb: d.strDrinkThumb };
                        cocktailMap[d.idDrink].count++;
                    });
                }
            } catch (_) {}
        }

        const sorted = Object.entries(cocktailMap)
            .sort((a, b) => b[1].count - a[1].count)
            .slice(0, 80);

        const batchSize = 10;
        for (let i = 0; i < sorted.length; i += batchSize) {
            const batch = sorted.slice(i, i + batchSize);
            const details = await Promise.all(
                batch.map(([id]) => fetch(`${API}/lookup.php?i=${id}`).then(r => r.json()))
            );
            details.forEach(data => {
                if (!data.drinks || !data.drinks[0]) return;
                const drink = data.drinks[0];
                const drinkIngredients = [];
                for (let j = 1; j <= 15; j++) {
                    const ing = drink[`strIngredient${j}`];
                    const measure = drink[`strMeasure${j}`];
                    if (ing && ing.trim()) drinkIngredients.push({ name: ing.trim(), measure: (measure || '').trim() });
                }
                let missing = [], have = [];
                drinkIngredients.forEach(di => {
                    ingredientMatch(di.name, selected) ? have.push(di) : missing.push(di);
                });
                if (missing.length <= 2) {
                    const obj = {
                        drink,
                        drinkIngredients,
                        missing, have,
                        flavor: classifyFlavor(drinkIngredients, null),
                        difficulty: getDifficulty(drinkIngredients.length),
                        steps: parseSteps(drink.strInstructions),
                        source: 'api'
                    };
                    if (missing.length === 0) fullMatch.push(obj);
                    else almostMatch.push(obj);
                }
            });
        }
    } catch (err) { console.warn('API error:', err); }

    // ── C) Deduplicate (local takes priority) ──
    function dedup(arr) {
        const seen = new Set();
        return arr.filter(c => {
            const key = norm(c.drink.strDrink);
            if (seen.has(key)) return false;
            seen.add(key);
            return true;
        });
    }
    const dedupFull = dedup(fullMatch);
    const dedupAlmost = dedup(almostMatch);

    // Store all for modal access
    allResults = [...dedupFull, ...dedupAlmost];

    // ── D) Render ──
    spinnerEl.style.display = 'none';
    let html = '';

    if (dedupFull.length > 0) {
        html += `<div class="main-section-title"><span class="icon">✅</span> You Can Make (${dedupFull.length})</div>`;
        html += buildFlavorSections(dedupFull, 'full');
    }
    if (dedupAlmost.length > 0) {
        html += `<div class="main-section-title"><span class="icon">🟡</span> Almost There (${dedupAlmost.length})</div>`;
        html += buildFlavorSections(dedupAlmost, 'almost');
    }
    if (dedupFull.length === 0 && dedupAlmost.length === 0) {
        html = '<div class="no-results">😕 No cocktails found. Try adding more ingredients!</div>';
    }
    resultsDiv.innerHTML = html;
}

/* ═══════════════════════════════════════
   BUILD FLAVOR SECTIONS
   ═══════════════════════════════════════ */
function buildFlavorSections(cocktails, prefix) {
    const groups = {};
    cocktails.forEach(c => {
        if (!groups[c.flavor]) groups[c.flavor] = [];
        groups[c.flavor].push(c);
    });
    let html = '';
    for (const profile of FLAVOR_PROFILES) {
        const list = groups[profile.key];
        if (!list || list.length === 0) continue;
        const uid = prefix + '-' + profile.key;
        html += `
        <div class="flavor-section">
            <div class="flavor-header" onclick="toggleFlavor('${uid}')">
                <span class="fl-emoji">${profile.emoji}</span>
                <span class="fl-title">${profile.title}</span>
                <span class="fl-count">${list.length} cocktail${list.length > 1 ? 's' : ''}</span>
                <span class="fl-arrow open" id="fa-${uid}">▼</span>
            </div>
            <div class="flavor-body" id="fb-${uid}">
                <div class="cards">
                    ${list.map(c => {
                        const idx = allResults.indexOf(c);
                        return compactCardHTML(c, idx);
                    }).join('')}
                </div>
            </div>
        </div>`;
    }
    return html;
}

/* ═══════════════════════════════════════
   COMPACT CARD
   ═══════════════════════════════════════ */
function compactCardHTML(c, index) {
    const d = c.drink;
    const img = d.strDrinkThumb || DEFAULT_IMG;
    const fp = getProfile(c.flavor);
    const diffClass = c.difficulty === 'Easy' ? 'badge-easy' : c.difficulty === 'Medium' ? 'badge-medium' : 'badge-advanced';
    return `
    <div class="card" onclick="openModal(${index})">
        <img src="${img}" alt="${d.strDrink}" loading="lazy" onerror="this.src='${DEFAULT_IMG}'">
        <div class="card-body">
            <h3>${d.strDrink}</h3>
            <div class="card-info">
                <span class="flavor-badge">${fp.emoji}</span>
                <span class="diff-badge ${diffClass}">${c.difficulty}</span>
                <span class="ing-count">${c.drinkIngredients.length} ingredients</span>
            </div>
        </div>
    </div>`;
}

/* ═══════════════════════════════════════
   MODAL
   ═══════════════════════════════════════ */
function openModal(index) {
    const c = allResults[index];
    if (!c) return;
    const d = c.drink;
    const img = d.strDrinkThumb || DEFAULT_IMG;
    const fp = getProfile(c.flavor);
    const diffClass = c.difficulty === 'Easy' ? 'badge-easy' : c.difficulty === 'Medium' ? 'badge-medium' : 'badge-advanced';

    const ingHTML = c.drinkIngredients.map(di => {
        const miss = c.missing.some(m => m.name === di.name);
        return `<li class="${miss ? 'missing' : ''}">${di.measure ? di.measure + ' ' : ''}${di.name}${miss ? ' (need this!)' : ''}</li>`;
    }).join('');

    const stepsHTML = c.steps.map(s => `<li><span>${s}</span></li>`).join('');

    document.getElementById('modalContent').innerHTML = `
        <img class="modal-img" src="${img}" alt="${d.strDrink}" onerror="this.src='${DEFAULT_IMG}'">
        <div class="modal-body">
            <h2>${d.strDrink}</h2>
            <div class="modal-meta">
                <span>${fp.emoji} ${fp.title}</span>
                <span>🍸 ${d.strGlass || 'Glass'}</span>
                <span class="diff-badge ${diffClass}">${c.difficulty}</span>
            </div>
            <h4>🧾 Ingredients</h4>
            <ul class="modal-ingredients">${ingHTML}</ul>
            <h4>📝 Instructions</h4>
            <ol class="modal-steps">${stepsHTML}</ol>
        </div>`;

    document.getElementById('modal').classList.add('open');
    document.body.style.overflow = 'hidden';
}

function closeModal() {
    document.getElementById('modal').classList.remove('open');
    document.body.style.overflow = '';
}

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>
