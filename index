  {name:"Cape Codder (Vodka Cranberry)",ingredients:[{name:"Vodka",measure:"2 oz"},{name:"Cranberry Juice",measure:"4 oz"},{name:"Lime",measure:"1 wedge"}],steps:["Fill a highball glass with ice.","Pour 2 oz vodka over the ice.","Add 4 oz cranberry juice.","Squeeze a lime wedge and drop it in.","Stir gently and serve."],glass:"Highball Glass",category:"Highball",flavor:"quick",difficulty:"Easy",img:""},
