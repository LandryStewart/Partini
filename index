  {name:"Black Russian",ingredients:[{name:"Vodka",measure:"2 oz"},{name:"Kahlua",measure:"1 oz"}],steps:["Fill an old fashioned glass with ice.","Pour 2 oz vodka over the ice.","Add 1 oz Kahlua.","Stir gently and serve."],glass:"Old Fashioned Glass",category:"Cocktail",flavor:"bold",difficulty:"Easy",img:""},
  {name:"White Russian",ingredients:[{name:"Vodka",measure:"2 oz"},{name:"Kahlua",measure:"1 oz"},{name:"Cream",measure:"1 oz"}],steps:["Fill an old fashioned glass with ice.","Pour 2 oz vodka over the ice.","Add 1 oz Kahlua and stir.","Float 1 oz heavy cream on top by pouring over the back of a spoon.","Stir if desired and serve."],glass:"Old Fashioned Glass",category:"Cocktail",flavor:"creamy",difficulty:"Easy",img:""},
